# Mobile App Environment Configuration
# Create this as .env in apps/mobile/

# Backend API Base URL - UPDATE THIS!
# For local development on Windows/Mac (Android Emulator):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# For local development on physical device:
# Replace 192.168.1.100 with your machine's IP address
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5000/api

# For production:
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api

EXPO_PUBLIC_API_URL=http://192.168.1.191:5000/api
