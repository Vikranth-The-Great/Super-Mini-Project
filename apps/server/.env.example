# Server Environment Configuration
# Copy this to .env and fill in your values

NODE_ENV=development
PORT=5000
SOCKET_IO_PORT=5000

# MongoDB Connection String
# Local: mongodb://localhost:27017/food-donation
# Cloud: mongodb+srv://username:password@cluster.mongodb.net/food-donation
MONGODB_URI=mongodb://localhost:27017/food-donation

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS Origins (optional, auto-detected in development)
REACT_APP_URL=http://localhost:5173
MOBILE_APP_URL=http://localhost:8081

# Optional: Third-party services
# SENDGRID_API_KEY=your_sendgrid_key
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
